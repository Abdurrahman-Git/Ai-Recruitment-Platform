# ─── LLM Configuration ───────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
# Or use Anthropic: https://console.anthropic.com/
OPENAI_API_KEY=sk-your-openai-key-here

# Which LLM model to use. GPT-4o is cheaper + fast. GPT-4-turbo is most capable.
LLM_MODEL=gpt-4o

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite for development (file-based, no setup needed)
DATABASE_URL=sqlite:///./recruitment.db

# For production, switch to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/recruitment_db

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_NAME=AI Recruitment Intelligence Platform
DEBUG=true
API_VERSION=v1
